# Residue — Environment Variables
# Copy this file to .env.local and fill in your values.

# MongoDB Atlas connection string
# Required for data persistence, time-series, and vector search
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/residue

# ElevenLabs API key for Sound Effects generation
# Required for generating personalized ambient beds
# Get one at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Fetch.ai Agentverse API key for study buddy matching
# Optional — enables cross-network agent discovery
# Get one at: https://agentverse.ai
AGENTVERSE_API_KEY=
