# Residue — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.

# MongoDB Atlas connection string
# Required for data persistence, time-series, and vector search
# Get one at: https://cloud.mongodb.com (free M0 tier)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/residue

# ElevenLabs API key for Sound Effects generation
# Required for AI-generated personalized ambient beds
# Get one at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ASI1-Mini API key (Fetch.ai's Web3-native LLM)
# Required for agent reasoning and cognitive state inference
# Get one at: https://asi1.ai/dashboard/api-keys
ASI1_API_KEY=

# Fetch.ai Agentverse API key for agent registration & discovery
# Required for Agentverse registration and ASI:One discoverability
# Get one at: https://agentverse.ai
AGENTVERSE_API_KEY=
